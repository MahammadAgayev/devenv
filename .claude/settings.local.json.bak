{
  "enabledMcpjsonServers": [
    "code-mcp"
  ],
  "enabledPlugins": {
    "uber-dev@agent-marketplace": true,
    "uber-reviewer@agent-marketplace": true
  },
  "extraKnownMarketplaces": {
    "uber-code/devexp-agent-marketplace": {
      "source": {
        "source": "directory",
        "path": "/home/user/.local/share/aifx/marketplaces/uber-code/devexp-agent-marketplace"
      }
    }
  },
  "permissions": {
    "allow": [
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)"
    ]
  }
}
