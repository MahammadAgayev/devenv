{
  "apiKeyHelper": "/home/user/.local/share/aifx/bin/claude-genai-token-helper",
  "effortLevel": "low",
  "enabledMcpjsonServers": [
    "code-mcp"
  ],
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "uber-dev@agent-marketplace": true,
    "uber-reviewer@agent-marketplace": true
  },
  "env": {
    "ENABLE_TOOL_SEARCH": "false"
  },
  "extraKnownMarketplaces": {
    "uber-code/devexp-agent-marketplace": {
      "source": {
        "path": "/home/user/.local/share/aifx/marketplaces/uber-code/devexp-agent-marketplace",
        "source": "directory"
      }
    }
  },
  "fastMode": false,
  "model": "opus",
  "otelHeadersHelper": "/home/user/.local/share/aifx/bin/claude-telemetry-token-helper",
  "permissions": {
    "allow": [
      "Bash(basename *)",
      "Bash(bazel build *)",
      "Bash(bazel test *)",
      "Bash(cat *)",
      "Bash(cut *)",
      "Bash(date *)",
      "Bash(diff *)",
      "Bash(dirname *)",
      "Bash(du *)",
      "Bash(echo *)",
      "Bash(env)",
      "Bash(file *)",
      "Bash(find *)",
      "Bash(git -C * diff *)",
      "Bash(git -C * log *)",
      "Bash(git -C * status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git status *)",
      "Bash(grep *)",
      "Bash(head *)",
      "Bash(jq *)",
      "Bash(ls *)",
      "Bash(printenv *)",
      "Bash(pwd)",
      "Bash(realpath *)",
      "Bash(sort *)",
      "Bash(stat *)",
      "Bash(tail *)",
      "Bash(test *)",
      "Bash(tree *)",
      "Bash(uniq *)",
      "Bash(wc *)",
      "Bash(which *)",
      "WebFetch",
      "mcp__monorepo-experts-mcp-server__generate_standard_go_mocks",
      "mcp__monorepo-experts-mcp-server__generate_glue_go_mocks",
      "mcp__monorepo-experts-mcp-server__update_build_files",
      "mcp__monorepo-experts-mcp-server__get_coverage_report"
    ],
    "defaultMode": "default",
    "deny": [
      "Bash(git commit *)",
      "Bash(git push *)"
    ]
  }
}