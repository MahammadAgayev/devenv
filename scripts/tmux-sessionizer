#!/usr/bin/env bash
# tmux-sessionizer — local tmux jump picker. Discover project dirs (flat roots
# + monorepo METADATA dirs via the git index), pick with fzf, jump to/create a
# session. Local only, no cache.

inside_tmux() {
    # $TMUX isn't exported when launched via run-shell/neww, so also probe the
    # server; trusting only $TMUX makes switch_to wedge on attach-session.
    [[ -n $TMUX ]] || [[ -n $(tmux list-clients 2>/dev/null) ]]
}

switch_to() {
    if inside_tmux; then
        tmux switch-client -t "$1"
    else
        tmux attach-session -t "$1"
    fi
}

has_session() {
    tmux has-session -t "$1" 2>/dev/null
}

hydrate() {
    if [[ -f "$2/.ssh" ]]; then
        tmux send-keys -t "$1" "ssh $(cat "$2/.ssh")" C-m
    fi
    if [[ -f "$2/.tmux-sessionizer" ]]; then
        tmux send-keys -t "$1" "source $2/.tmux-sessionizer" C-m
    elif [[ -f "$HOME/.tmux-sessionizer" ]]; then
        tmux send-keys -t "$1" "source $HOME/.tmux-sessionizer" C-m
    fi
}

# --- discovery -------------------------------------------------------------
# Monorepo roots (fixed): project dir = dir of each git-tracked METADATA file,
# read straight from the git index (instant). Everything else is flat depth-1.

MONO_ROOTS=("$HOME/go-code" "$HOME/fievel" "$HOME/web-code")
DENY='/(\.[^/]*|Library|Applications|Movies|Music|Pictures|Public|Desktop|Downloads|Zoom|google-workspace|go-code|fievel|web-code)$'

emit_flat() {
    [[ -d "$1" ]] || return
    find "$1" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | grep -vE "$DENY"
}

emit_mono() {
    local root="$1"
    [[ -d "$root" ]] || return
    [[ $(git -C "$root" rev-parse --is-inside-work-tree 2>/dev/null) == true ]] || return
    git -C "$root" ls-files -- '*METADATA' 2>/dev/null \
        | sed 's:/METADATA$::;s:^METADATA$:.:' \
        | sort -u \
        | sed "s:^:$root/:;s:/\.$::"
}

build_table() {
    {
        emit_flat "$HOME"
        emit_flat "$HOME/Uber"
        emit_flat "$HOME/Documents"
        emit_flat "$HOME/Documents/src"
        emit_flat "$HOME/src"
        for r in "${MONO_ROOTS[@]}"; do emit_mono "$r"; done
    } | TSZ_WINS="$(tmux list-windows -a -F '#S	#I	#W' 2>/dev/null)" awk -v home="$HOME/" '
        BEGIN {
            nw=split(ENVIRON["TSZ_WINS"], wl, "\n"); wc=0
            for (i=1;i<=nw;i++) {
                if (wl[i]=="") continue
                split(wl[i], f, "\t"); wc++
                wsess[wc]=f[1]; widx[wc]=f[2]; wname[wc]=f[3]
                open[f[1]]=1; wincount[f[1]]++
            }
        }
        { path=$0
          label=path; sub("^"home,"",label); sub("src/code.uber.internal/","",label)
          nm=path; sub(".*/","",nm); gsub(/\./,"_",nm)
          if (nm in open) { if (!(nm in lbl)) lbl[nm]=label; next }
          print "1\t" label "\t" path }
        END {
            for (i=1;i<=wc;i++) {
                s=wsess[i]; base=(s in lbl)?lbl[s]:s
                disp=(wincount[s]>1)?(base " \342\226\270 " wname[i]):base
                print "0\t\342\227\217 " disp "\t\t" s ":" widx[i]
            }
        }' \
      | sort -s -t"$(printf '\t')" -k1,1
}

[[ "$1" == --emit ]] && { build_table; exit 0; }

# --- selection -------------------------------------------------------------

if [[ $# -eq 1 ]]; then
    selected="$1"
else
    result=$(build_table | fzf \
        --delimiter=$'\t' --with-nth=2 --print-query \
        --prompt='' --height=100% --reverse --tiebreak=index)
    query=$(sed -n 1p <<<"$result")
    picked=$(sed -n 2p <<<"$result")
    if [[ -n "$picked" ]]; then
        selected=$(printf '%s' "$picked" | cut -f3)
        # dir-less live session (col3 empty): jump straight to it
        if [[ -z "$selected" ]]; then
            switch_to "$(printf '%s' "$picked" | cut -f4)"
            exit 0
        fi
    elif [[ -n "$query" ]]; then
        selected="${query/#\~/$HOME}"
        [[ "$selected" != /* ]] && selected="$PWD/$selected"
    fi
fi

[[ -z "$selected" || ! -d "$selected" ]] && exit 0

selected_name=$(basename "$selected" | tr . _)

if ! inside_tmux && [[ -z $(pgrep tmux) ]]; then
    tmux new-session -s "$selected_name" -c "$selected"
    hydrate "$selected_name" "$selected"
    exit 0
fi

if ! has_session "$selected_name"; then
    tmux new-session -ds "$selected_name" -c "$selected"
    sleep 0.1
    hydrate "$selected_name" "$selected"
fi

switch_to "$selected_name"
