#!/usr/bin/env python3
"""tmux-sessionizer — unified jump picker.

One fzf list, three kinds of rows, no duplicates:
  • local tmux windows   (open work; single-window sessions = one clean row)
  • project directories   (not yet open; selecting one creates a session)
  • remote tmux windows   (windows of remote servers reached via live tssh)

Cross-remote session jumping stays on tmux's own `C-b s`; this tool owns
window-level jumping so you never need the nested `C-b b n` dance.
"""

from __future__ import annotations

import os
import re
import subprocess
import sys
import time
from concurrent.futures import ThreadPoolExecutor
from pathlib import Path

HOME = Path.home()
MONO_ROOTS = [HOME / "go-code", HOME / "fievel"]
FLAT_ROOTS = [HOME / "Uber", HOME / "Documents", HOME / "Documents" / "src", HOME / "src"]
CACHE_DIR = Path(os.environ.get("XDG_CACHE_HOME", HOME / ".cache")) / "tmux-sessionizer"

# depth-1 dir names to drop everywhere: dotfiles handled separately
DENY = {"Library", "Applications", "Movies", "Music", "Pictures", "Public",
        "Desktop", "Downloads", "Zoom", "google-workspace", "go-code", "fievel"}

WIN_FMT = "#{session_name}\t#{window_index}\t#{window_name}\t#{window_active}"

# ssh flags that consume the following token (so we skip it when finding host)
SSH_OPT_WITH_ARG = {"-b", "-c", "-D", "-E", "-e", "-F", "-I", "-i", "-J", "-L",
                    "-l", "-m", "-O", "-o", "-p", "-Q", "-R", "-S", "-W", "-w"}


# --- shell helpers ---------------------------------------------------------

def run(cmd: list[str], timeout: float | None = None) -> str:
    try:
        return subprocess.run(cmd, capture_output=True, text=True,
                              timeout=timeout).stdout
    except (subprocess.SubprocessError, OSError):
        return ""


def tmux(*args: str) -> str:
    return run(["tmux", *args])


def ssh(host: str, remote_cmd: str, timeout: float = 3) -> str:
    return run(["ssh", "-o", "BatchMode=yes", "-o", f"ConnectTimeout={int(timeout)}",
                host, remote_cmd], timeout=timeout + 1)


# --- discovery -------------------------------------------------------------

def denied(name: str) -> bool:
    return name.startswith(".") or name in DENY


def children(root: Path):
    if not root.is_dir():
        return
    for p in sorted(root.iterdir()):
        if p.is_dir() and not denied(p.name):
            yield p


def mono(root: Path, rebuild: bool):
    """Project dirs of a monorepo = the dir of each METADATA file. Cached; a
    stale cache (>12h) is served now and refreshed in the background."""
    if not root.is_dir():
        return
    CACHE_DIR.mkdir(parents=True, exist_ok=True)
    cache = CACHE_DIR / (str(root).replace("/", "_") + ".list")

    def rebuild_cache(dest: Path):
        out = run(["rg", "--files", "--no-messages", "-g", "METADATA", str(root)])
        dirs = sorted({line[: -len("/METADATA")] for line in out.splitlines()
                       if line.endswith("/METADATA")})
        dest.write_text("\n".join(dirs) + ("\n" if dirs else ""))

    if rebuild or not cache.exists():
        rebuild_cache(cache)
    elif time.time() - cache.stat().st_mtime > 12 * 3600:
        subprocess.Popen(  # background refresh, serve current cache now
            [sys.executable, __file__, "--refresh-mono", str(root)],
            stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)

    for line in cache.read_text().splitlines():
        if line:
            yield Path(line)


def iter_dirs(rebuild: bool):
    yield from children(HOME)
    for r in FLAT_ROOTS:
        yield from children(r)
    for r in MONO_ROOTS:
        yield from mono(r, rebuild)


def label(path: Path) -> str:
    s = str(path).replace(str(HOME) + "/", "")
    return s.replace("src/code.uber.internal/", "")


def sess_name(path: Path) -> str:
    return path.name.replace(".", "_")


# --- tmux introspection ----------------------------------------------------

def parse_windows(out: str) -> dict[str, list[tuple[str, str, bool]]]:
    """text -> {session: [(index, wname, active), ...]}"""
    by_sess: dict[str, list[tuple[str, str, bool]]] = {}
    for line in out.splitlines():
        parts = line.split("\t")
        if len(parts) != 4:
            continue
        sess, idx, wname, active = parts
        by_sess.setdefault(sess, []).append((idx, wname, active == "1"))
    return by_sess


def session_host(sess: str) -> str | None:
    """If a local session is a tssh connection, return its ssh host."""
    pid = tmux("list-panes", "-t", sess, "-F", "#{pane_pid}").splitlines()
    if not pid:
        return None
    kids = run(["pgrep", "-P", pid[0]]).split()
    for child in kids:
        cmd = run(["ps", "-o", "command=", "-p", child])
        host = ssh_host_of(cmd)
        if host:
            return host
    return None


def ssh_host_of(cmd: str) -> str | None:
    toks = cmd.split()
    i = next((j for j, t in enumerate(toks)
              if os.path.basename(t) == "ssh"), None)
    if i is None:
        return None
    i += 1
    while i < len(toks):
        t = toks[i]
        if t.startswith("-"):
            i += 2 if t in SSH_OPT_WITH_ARG else 1
            continue
        return t
    return None


# --- table -----------------------------------------------------------------

def build_table(rebuild: bool = False) -> list[tuple]:
    """Rows: (action, bucket, display, *targets). Sorted by bucket, stable.
    bucket 0 = open local windows, 2 = closed dirs, 3 = remote windows."""
    dirs = list(iter_dirs(rebuild))
    dir_by_name: dict[str, Path] = {}
    for p in dirs:
        dir_by_name.setdefault(sess_name(p), p)

    local = parse_windows(tmux("list-windows", "-a", "-F", WIN_FMT))
    rows: list[tuple] = []
    open_names: set[str] = set()
    hosts: dict[str, str] = {}  # ssh host -> local tssh session

    for sess, wins in local.items():
        host = session_host(sess)
        if host:  # tssh connection: represented by its remote windows below
            hosts.setdefault(host, sess)
            continue
        open_names.add(sess)
        disp = label(dir_by_name[sess]) if sess in dir_by_name else sess
        if len(wins) == 1:
            rows.append(("win", 0, f"\u25cf {disp}", sess))
        else:
            for idx, wname, _ in wins:
                rows.append(("win", 0, f"\u25cf {disp} \u25b8 {wname}", f"{sess}:{idx}"))

    for p in dirs:
        if sess_name(p) not in open_names:
            rows.append(("dir", 2, label(p), str(p)))

    if hosts:
        with ThreadPoolExecutor(max_workers=len(hosts)) as pool:
            results = list(pool.map(
                lambda h: (h, hosts[h], parse_windows(
                    ssh(h, f"tmux list-windows -a -F '{WIN_FMT}' 2>/dev/null"))),
                hosts))
        for host, lsess, rwins in results:
            for sess, wins in rwins.items():
                if len(wins) == 1:
                    rows.append(("remotewin", 3, f"{host} \u25b8 {sess}",
                                 host, lsess, sess))
                else:
                    for idx, wname, _ in wins:
                        rows.append(("remotewin", 3,
                                     f"{host} \u25b8 {sess} \u25b8 {wname}",
                                     host, lsess, f"{sess}:{idx}"))

    rows.sort(key=lambda r: r[1])  # stable
    return rows


def emit(rebuild: bool = False):
    for row in build_table(rebuild):
        print("\t".join(str(c) for c in row))


# --- jumps -----------------------------------------------------------------

def switch_to(target: str):
    if os.environ.get("TMUX"):
        tmux("switch-client", "-t", target)
    else:
        tmux("attach-session", "-t", target)


def has_session(name: str) -> bool:
    return subprocess.run(["tmux", "has-session", "-t", name],
                          capture_output=True).returncode == 0


def hydrate(name: str, path: Path):
    ssh_file = path / ".ssh"
    if ssh_file.is_file():
        tmux("send-keys", "-t", name, f"ssh {ssh_file.read_text().strip()}", "C-m")
    for tsz in (path / ".tmux-sessionizer", HOME / ".tmux-sessionizer"):
        if tsz.is_file():
            tmux("send-keys", "-t", name, f"source {tsz}", "C-m")
            break


def jump_dir(path: Path):
    if not path.is_dir():
        return
    name = sess_name(path)
    if not os.environ.get("TMUX") and not run(["pgrep", "tmux"]).strip():
        tmux("new-session", "-s", name, "-c", str(path))
        hydrate(name, path)
        return
    if not has_session(name):
        tmux("new-session", "-ds", name, "-c", str(path))
        time.sleep(0.1)
        hydrate(name, path)
    switch_to(name)


def jump_remote(host: str, lsess: str, target: str):
    """Show the tssh connection locally, then drive the remote server's own
    client (shared unix socket, one client per remote) via ssh."""
    switch_to(lsess)
    ssh(host, "tty=$(tmux list-clients -F '#{client_tty}' | head -1); "
              f"tmux switch-client -c \"$tty\" -t '{target}'")


# --- fzf -------------------------------------------------------------------

PREVIEW = (
    'a=$(printf "%s" {} | cut -f1); t=$(printf "%s" {} | cut -f4); '
    'if [ "$a" = dir ]; then ls -a "$t" 2>/dev/null | head -40; echo; '
    'git -C "$t" log -1 --oneline 2>/dev/null; else printf "%s" {} | cut -f3; fi'
)


def pick() -> tuple[str, str] | None:
    """Run fzf; return (action, line) or None. Falls back to the typed query
    as a directory when nothing matches."""
    table = "\n".join("\t".join(str(c) for c in r) for r in build_table())
    proc = subprocess.run(
        ["fzf", "--delimiter=\t", "--with-nth=3", "--print-query",
         "--prompt=", "--height=40%", "--reverse", "--tiebreak=index",
         "--preview", PREVIEW, "--preview-window=right,50%",
         "--bind", f"ctrl-r:reload({sys.argv[0]} --emit-rebuild)"],
        input=table, capture_output=True, text=True)
    out = proc.stdout.split("\n")
    query = out[0] if out else ""
    picked = out[1] if len(out) > 1 else ""
    if picked:
        return picked.split("\t")[0], picked
    if query:
        p = Path(query).expanduser()
        if not p.is_absolute():
            p = Path.cwd() / p
        return "dir", f"dir\t\t\t{p}"
    return None


# --- main ------------------------------------------------------------------

def main():
    if len(sys.argv) == 3 and sys.argv[1] == "--refresh-mono":
        root = Path(sys.argv[2])
        cache = CACHE_DIR / (str(root).replace("/", "_") + ".list")
        tmp = cache.with_suffix(".tmp")
        out = run(["rg", "--files", "--no-messages", "-g", "METADATA", str(root)])
        dirs = sorted({l[: -len("/METADATA")] for l in out.splitlines()
                       if l.endswith("/METADATA")})
        tmp.write_text("\n".join(dirs) + ("\n" if dirs else ""))
        tmp.replace(cache)
        return
    if len(sys.argv) == 2 and sys.argv[1] == "--emit":
        return emit()
    if len(sys.argv) == 2 and sys.argv[1] == "--emit-rebuild":
        return emit(rebuild=True)

    if len(sys.argv) == 2:  # direct: tmux-sessionizer <dir>
        jump_dir(Path(sys.argv[1]).expanduser())
        return

    result = pick()
    if not result:
        return
    action, line = result
    cols = line.split("\t")
    if action == "dir":
        jump_dir(Path(cols[3]).expanduser())
    elif action == "win":
        switch_to(cols[3])
    elif action == "remotewin":
        jump_remote(cols[3], cols[4], cols[5])


if __name__ == "__main__":
    main()
